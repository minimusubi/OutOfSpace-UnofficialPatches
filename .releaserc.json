{
	"branches": ["main"],
	"plugins": [
		[
			"semantic-release-replace-plugin",
			{
				"replacements": [
					{
						"files": ["UnofficialPatches/UnofficialPatches.csproj"],
						"from": "0.0.0",
						"to": "0.${nextRelease.version}",
						"results": [
							{
								"file": "UnofficialPatches/UnofficialPatches.csproj",
								"hasChanged": true,
								"numMatches": 1,
								"numReplacements": 1
							}
						],
						"countMatches": true
					}
				]
			}
		],
		[
			"@semantic-release/exec",
			{
				"prepareCmd": "dotnet build --no-restore --property:Configuration=Release"
			}
		],
		"@semantic-release/commit-analyzer",
		"@semantic-release/release-notes-generator",
		[
			"@semantic-release/github",
			{
				"assets": "./UnofficialPatches/bin/Release/net472/UnofficialPatches.dll"
			}
		]
	]
}
